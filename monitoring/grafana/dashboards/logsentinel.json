{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "LogSentinel system overview: log ingestion rate, anomaly detection, service health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Log Ingestion Rate (logs/sec)",
      "id": 1,
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 500}
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(logs_ingested_total[1m]))",
          "legendFormat": "Logs/sec"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Anomalies Detected (last 1h)",
      "id": 2,
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"],"fields": "","values": false}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "increase(ml_engine_anomalies_detected_total[1h])",
          "legendFormat": "Anomalies"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Services Up",
      "id": 3,
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"],"fields": "","values": false}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 3},
              {"color": "green", "value": 5}
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "count(up{job=~\"log-ingestion-api|ml-engine|dashboard-backend\"} == 1)",
          "legendFormat": "Services Up"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Kafka Consumer Lag",
      "id": 4,
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 10000}
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(kafka_consumergroup_lag)",
          "legendFormat": "Total Lag"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Log Ingestion Rate Over Time",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "options": {"tooltip": {"mode": "multi"}},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(logs_ingested_total[1m]))",
          "legendFormat": "Logs/sec"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Anomaly Detection Count Over Time",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}, "color": {"fixedColor": "red", "mode": "fixed"}}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(ml_engine_anomalies_detected_total[5m]) * 60",
          "legendFormat": "Anomalies/min"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Request Latency (p50, p95, p99)",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "fieldConfig": {
        "defaults": {"unit": "s"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"log-ingestion-api\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"log-ingestion-api\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"log-ingestion-api\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Kafka Publish Rate",
      "id": 8,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(kafka_publish_success_total[1m]))",
          "legendFormat": "Published/sec"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(rate(kafka_publish_errors_total[1m]))",
          "legendFormat": "Errors/sec"
        }
      ]
    },
    {
      "type": "table",
      "title": "Service Health Status",
      "id": 9,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 20},
      "options": {"showHeader": true},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "up{job=~\"log-ingestion-api|ml-engine|dashboard-backend|kafka-exporter|node-exporter\"}",
          "instant": true,
          "legendFormat": "{{ job }}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["logsentinel", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "LogSentinel Overview",
  "uid": "logsentinel-overview",
  "version": 1
}
