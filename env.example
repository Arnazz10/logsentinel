# =============================================================================
# LogSentinel — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_LOGS=raw-logs
KAFKA_TOPIC_PROCESSED_LOGS=processed-logs
KAFKA_TOPIC_ANOMALY_ALERTS=anomaly-alerts
KAFKA_CONSUMER_GROUP_PROCESSOR=log-processor-group
KAFKA_CONSUMER_GROUP_ML=ml-engine-group
KAFKA_CONSUMER_GROUP_ALERT=alert-service-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=500

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=http
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX_LOGS=logsentinel-logs
ELASTICSEARCH_INDEX_ANOMALIES=logsentinel-anomalies
ELASTICSEARCH_TIMEOUT=30

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=logsentinel
POSTGRES_USER=logsentinel
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://logsentinel:changeme@postgres:5432/logsentinel

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
ALERT_DEDUP_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# Log Ingestion API
# -----------------------------------------------------------------------------
INGESTION_API_HOST=0.0.0.0
INGESTION_API_PORT=8000
INGESTION_API_WORKERS=4
INGESTION_MAX_BATCH_SIZE=100
INGESTION_RATE_LIMIT_PER_MINUTE=10000

# -----------------------------------------------------------------------------
# ML Engine
# -----------------------------------------------------------------------------
ML_ENGINE_HOST=0.0.0.0
ML_ENGINE_PORT=8001
ML_ENGINE_WORKERS=2
ML_MODEL_PATH=/app/models/isolation_forest.joblib
ML_SCALER_PATH=/app/models/scaler.joblib
ML_CONTAMINATION=0.05
ML_N_ESTIMATORS=100
ML_RANDOM_STATE=42
ML_ANOMALY_SCORE_THRESHOLD=-0.1

# -----------------------------------------------------------------------------
# Dashboard Backend
# -----------------------------------------------------------------------------
DASHBOARD_API_HOST=0.0.0.0
DASHBOARD_API_PORT=8002
DASHBOARD_API_WORKERS=2
DASHBOARD_DEFAULT_PAGE_SIZE=20
DASHBOARD_MAX_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# Alert Service
# -----------------------------------------------------------------------------
ALERT_COOLDOWN_SECONDS=300
ALERT_MAX_RETRIES=3
ALERT_RETRY_BACKOFF_SECONDS=5

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#logsentinel-alerts
SLACK_USERNAME=LogSentinel Bot
SLACK_ICON_EMOJI=:shield:
SLACK_ENABLED=true

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=logsentinel@your-domain.com
SMTP_FROM_NAME=LogSentinel
SMTP_TO_EMAILS=ops-team@your-domain.com,alerts@your-domain.com
SMTP_USE_TLS=true
SMTP_ENABLED=true

# -----------------------------------------------------------------------------
# Prometheus
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_INSTALL_PLUGINS=grafana-clock-panel,grafana-simple-json-datasource

# -----------------------------------------------------------------------------
# AWS (for production deployments)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=logsentinel-logs
AWS_S3_PREFIX=logs/
AWS_SECRETS_MANAGER_REGION=us-east-1

# ECR Registry
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_REPOSITORY_PREFIX=logsentinel

# -----------------------------------------------------------------------------
# Kubernetes (for CI/CD)
# -----------------------------------------------------------------------------
KUBE_NAMESPACE=logsentinel
KUBE_CONFIG_DATA=

# -----------------------------------------------------------------------------
# Docker Hub (for CI/CD)
# -----------------------------------------------------------------------------
DOCKER_USERNAME=your-dockerhub-username
DOCKER_PASSWORD=your-dockerhub-password
DOCKER_REGISTRY=docker.io

# -----------------------------------------------------------------------------
# GitHub Actions Secrets (reference only — set in GitHub repo settings)
# -----------------------------------------------------------------------------
# DOCKERHUB_USERNAME
# DOCKERHUB_TOKEN
# AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY
# KUBE_CONFIG_DATA
# SLACK_WEBHOOK_URL
# SONAR_TOKEN
